# ============================================================
#  Onchain-Wallet-Intelligence-API — .env.example
#  Copy to .env and fill in your values before running.
#    cp .env.example .env
#
#  NEVER commit .env to Git — it's in .gitignore.
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Data Providers ────────────────────────────────────────────
# Get your keys here:
#   Covalent  → https://www.covalenthq.com/platform/
#   Alchemy   → https://dashboard.alchemy.com/
#   Etherscan → https://etherscan.io/myapikey

COVALENT_API_KEY=your_covalent_api_key_here
ALCHEMY_API_KEY=your_alchemy_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Provider Priority ─────────────────────────────────────────
PROVIDER_ORDER=covalent,alchemy,etherscan

# ── Analytics Config ──────────────────────────────────────────
WHALE_VOLUME_THRESHOLD_USD=100000
RECURRING_TX_COUNT=3
TOP_WALLET_LIMIT=50
LOOKBACK_BLOCKS=50000
MIN_VOLUME_USD=0

# ── CORS ──────────────────────────────────────────────────────
# Local dev:   http://localhost:3001
# Production:  https://your-app.vercel.app
FRONTEND_URL=http://localhost:3001
